generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WatchlistRole {
  OWNER
  COLLABORATOR
}

enum WatchlistItemStatus {
  QUEUED
  WATCHED
}

enum WatchlistMediaType {
  MOVIE
  TV
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String           @id @default(cuid())
  name              String?
  email             String?          @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  ownedWatchlists   Watchlist[]       @relation("WatchlistOwner")
  watchlistInvites  WatchlistInvite[] @relation("WatchlistInviteInviter")
  watchlistItems    WatchlistItem[]   @relation("WatchlistItemAddedBy")
  watchlistMembers  WatchlistMember[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Watchlist {
  id          String            @id @default(cuid())
  name        String
  description String?
  mediaType   WatchlistMediaType
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  invites     WatchlistInvite[]
  items       WatchlistItem[]
  members     WatchlistMember[]
  owner       User              @relation("WatchlistOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model WatchlistMember {
  id          String        @id @default(cuid())
  watchlistId String
  userId      String
  role        WatchlistRole @default(COLLABORATOR)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist   Watchlist     @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, userId])
  @@index([userId])
}

model WatchlistInvite {
  id         String     @id @default(cuid())
  watchlistId String
  inviterId  String
  email      String
  tokenHash  String     @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  inviter    User       @relation("WatchlistInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  watchlist  Watchlist  @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@index([watchlistId, email])
  @@index([email])
}

model WatchlistItem {
  id           String              @id @default(cuid())
  watchlistId  String
  tmdbId       Int
  position     Int
  status       WatchlistItemStatus @default(QUEUED)
  note         String              @default("")
  title        String
  creditNames  String?
  year         Int?
  posterPath   String?
  backdropPath String?
  overview     String?
  watchedAt    DateTime?
  addedById    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  addedBy      User                @relation("WatchlistItemAddedBy", fields: [addedById], references: [id], onDelete: Restrict)
  watchlist    Watchlist           @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, tmdbId])
  @@index([watchlistId, position])
  @@index([addedById])
}
